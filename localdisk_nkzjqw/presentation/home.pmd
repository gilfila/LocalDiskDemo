{
  "id": "home",
  "endPoints": [
    {
      "name": "currentUser",
      "baseUrlType": "workday-staffing",
      "url": "/workers/me",
      "authType": "sso"
    }
  ],
  "presentation": {
    "title": {
      "type": "title",
      "label": "Parking Registration DEMO"
    },
    "body": {
      "type": "section",
      "horizontal": false,
      "children": [
        {
          "type": "fieldSet",
          "id": "profileSection",
          "title": "My Profile",
          "children": [
            {
              "type": "text",
              "id": "profileName",
              "label": "Name",
              "enabled": false,
              "value": "<% currentUser.descriptor %>"
            },
            {
              "type": "text",
              "id": "profileBusinessTitle",
              "label": "Business Title",
              "enabled": false,
              "value": "<% currentUser.primaryJob.businessTitle %>"
            },
            {
              "type": "text",
              "id": "profileLocation",
              "label": "Primary Work Location",
              "enabled": false,
              "value": "<% currentUser.primaryJob.location.descriptor %>"
            }
          ]
        }
      ]
    },
    "footer": {
      "type": "footer",
      "children": [
        {
          "type": "richText",
          "enabled": false,
          "value": "Powered By Workday Extend"
        }
      ]
    }
  }
}
